# Server
PORT=8080
ENVIRONMENT=development

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fzsmphone?sslmode=disable
# Or use individual params:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=fzsmphone
# DB_SSLMODE=disable

# JWT
JWT_SECRET=your-secret-key-change-this-in-production

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback

# Discord Guild & Role Verification
# Bot token is required for guild membership + role checking
DISCORD_BOT_TOKEN=your-discord-bot-token
# Guild ID — only members of this server can log in (leave empty to disable)
DISCORD_GUILD_ID=1134557553011998840
# Required role IDs — comma-separated (leave empty to only check membership)
DISCORD_REQUIRED_ROLE_IDS=1335363403870502912
# Role match mode: "all" = must have ALL roles, "any" = must have at least one
DISCORD_ROLE_MATCH=all
# Custom error message shown when verification fails
DISCORD_AUTH_FAIL_MESSAGE=请先加入指定服务器并完成身份组验证

# Frontend
FRONTEND_URL=http://localhost:3000
