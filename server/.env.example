# 服务器配置
PORT=8080
ENVIRONMENT=development

# 数据库（PostgreSQL）
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fzsmphone?sslmode=disable
# 或者使用单独的参数：
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=fzsmphone
# DB_SSLMODE=disable

# JWT 密钥
JWT_SECRET=your-secret-key-change-this-in-production

# Discord OAuth 配置
DISCORD_CLIENT_ID=你的Discord应用客户端ID
DISCORD_CLIENT_SECRET=你的Discord应用客户端密钥
DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback

# Discord 服务器 & 身份组验证
# Bot Token（可选 — 仅作为回退方案，主要通过用户 OAuth token 验证，无需 Bot）
DISCORD_BOT_TOKEN=
# 服务器 ID — 只有该服务器的成员才能登录（留空则不检查）
DISCORD_GUILD_ID=1134557553011998840
# 必须拥有的身份组 ID — 多个用英文逗号分隔（留空则只检查是否为成员）
DISCORD_REQUIRED_ROLE_IDS=1335363403870502912
# 身份组匹配模式："all" = 必须拥有全部身份组，"any" = 拥有任一即可
DISCORD_ROLE_MATCH=all
# 验证失败时显示的错误提示
DISCORD_AUTH_FAIL_MESSAGE=请先加入指定服务器并完成身份组验证
# 管理员 Discord ID — 登录时自动提升为 admin 角色（多个用英文逗号分隔）
DISCORD_ADMIN_IDS=1415357787352858797

# 前端地址（用于 CORS 跨域配置）
FRONTEND_URL=http://localhost:3000
