# API Configuration
VITE_API_URL=http://localhost:8080

# Security Settings
# Comma-separated list of allowed origins (e.g., http://localhost:3000,https://example.com)
VITE_ALLOWED_ORIGINS=
# Comma-separated list of allowed hostnames
VITE_ALLOWED_HOSTS=

# Debug Mode (set to 1 to enable debug logging in production)
# WARNING: Never enable in production unless debugging!
VITE_DEBUG_MODE=0